## Backend environment (copy to .env)
## Never commit real secrets.

# Server
PORT=5000
NODE_ENV=development

# Neon / Postgres
# Example (DO NOT USE THIS VALUE): postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=
# Neon typically requires SSL. Set to "false" only for local non-SSL Postgres.
DATABASE_SSL=true

# Auth0 (optional; only needed if you use /api/auth/* protected routes)
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

